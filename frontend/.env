# Google OAuth Client ID — required for Google Login/Signup
# HOW TO GET ONE:
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create a new project or select existing
# 3. Go to "OAuth consent screen" → configure (External, add your email)
# 4. Go to "Credentials" → "Create Credentials" → "OAuth client ID"
# 5. Application type: "Web application"
# 6. Add "http://localhost:5173" to Authorized JavaScript Origins
# 7. Click Create, copy the Client ID
#
# The value below is a MASKED placeholder. REPLACE with your real Client ID.
# A real ID looks like: 1234567890-abc123def456.apps.googleusercontent.com
VITE_API_URL=http://localhost:5000
VITE_GOOGLE_CLIENT_ID=697850144909-s1d5uklte802ufcq8ogv7tsq9da4ab7g.apps.googleusercontent.com

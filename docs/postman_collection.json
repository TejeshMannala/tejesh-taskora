{
  "info": {
    "name": "Taskora Core API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "groupId", "value": "" },
    { "key": "subjectId", "value": "" },
    { "key": "taskId", "value": "" },
    { "key": "email", "value": "student@example.com" },
    { "key": "otp", "value": "" },
    { "key": "educationType", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "AUTH",
      "item": [
        {
          "name": "Signup",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/signup",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student User\",\n  \"email\": \"{{email}}\",\n  \"password\": \"Password123!\",\n  \"college\": \"Demo College\",\n  \"educationType\": \"B.Tech\",\n  \"group\": \"{{groupId}}\",\n  \"academicYear\": \"1st Year\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"password\": \"Password123!\"\n}"
            }
          }
        },
        {
          "name": "Google Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/google",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"credential\": \"GOOGLE_ID_TOKEN_OR_ACCESS_TOKEN\"\n}"
            }
          }
        },
        {
          "name": "Auth Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/profile" }
        }
      ]
    },
    {
      "name": "OTP / FORGOT PASSWORD",
      "item": [
        {
          "name": "Send OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/otp/send-otp",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.otp) {",
                  "  pm.collectionVariables.set('otp', jsonData.otp);",
                  "  console.log('OTP for testing:', jsonData.otp);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Verify OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/otp/verify",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\"\n}"
            }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/otp/reset-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{email}}\",\n  \"otp\": \"{{otp}}\",\n  \"newPassword\": \"NewPassword123!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "PROFILE & ACADEMIC",
      "item": [
        {
          "name": "Get Education Types",
          "request": { "method": "GET", "url": "{{baseUrl}}/education/types" }
        },
        {
          "name": "Get Groups by Education Type",
          "request": { "method": "GET", "url": "{{baseUrl}}/education/groups?educationType=B.Tech" }
        },
        {
          "name": "Get Subjects by Group",
          "request": { "method": "GET", "url": "{{baseUrl}}/education/subjects?group={{groupId}}" }
        },
        {
          "name": "Get Academic Groups",
          "request": { "method": "GET", "url": "{{baseUrl}}/academic/groups?educationType=B.Tech" }
        },
        {
          "name": "Get Academic Subjects",
          "request": { "method": "GET", "url": "{{baseUrl}}/academic/subjects?group={{groupId}}" }
        },
        {
          "name": "Get Profile",
          "request": { "method": "GET", "url": "{{baseUrl}}/users/profile" }
        },
        {
          "name": "Update Profile (First time — locks academic fields)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Student User\",\n  \"college\": \"Demo College\",\n  \"educationType\": \"B.Tech\",\n  \"group\": \"{{groupId}}\",\n  \"semesterYear\": \"Semester 1\",\n  \"academicYear\": \"2026-2027\"\n}"
            }
          }
        },
        {
          "name": "Update Profile (After lock — name only)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/users/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Student Name\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "SUBJECTS",
      "item": [
        { "name": "List My Subjects", "request": { "method": "GET", "url": "{{baseUrl}}/subjects" } },
        {
          "name": "Create Subject",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/subjects",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Data Structures\",\n  \"color\": \"#7c3aed\",\n  \"targetHours\": 40\n}" }
          }
        },
        {
          "name": "Update Subject",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/subjects/{{subjectId}}",
            "body": { "mode": "raw", "raw": "{\n  \"targetHours\": 60\n}" }
          }
        },
        { "name": "Delete Subject", "request": { "method": "DELETE", "url": "{{baseUrl}}/subjects/{{subjectId}}" } }
      ]
    },
    {
      "name": "TASKS",
      "item": [
        { "name": "List Tasks", "request": { "method": "GET", "url": "{{baseUrl}}/tasks" } },
        {
          "name": "Create Task With Reminder",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/tasks",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Study DSA\",\n  \"subject\": \"Data Structures\",\n  \"durationMinutes\": 60,\n  \"priority\": \"High\",\n  \"date\": \"2026-07-01\",\n  \"dueDate\": \"2026-07-01T20:00:00.000Z\",\n  \"reminderEnabled\": true,\n  \"reminders\": { \"enabled\": true, \"frequencyMinutes\": 5 },\n  \"notes\": \"Revise trees and graphs\"\n}"
            }
          }
        },
        { "name": "Toggle Task Complete", "request": { "method": "PATCH", "url": "{{baseUrl}}/tasks/{{taskId}}/toggle" } },
        { "name": "Delete Task", "request": { "method": "DELETE", "url": "{{baseUrl}}/tasks/{{taskId}}" } }
      ]
    },
    {
      "name": "ADMIN — SEED",
      "item": [
        {
          "name": "Seed Academic Data",
          "request": { "method": "POST", "url": "{{baseUrl}}/admin/academic/seed" }
        }
      ]
    },
    {
      "name": "ADMIN — GROUPS",
      "item": [
        {
          "name": "List Groups",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/groups" }
        },
        {
          "name": "List Groups by Education Type",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/groups?educationType=B.Tech" }
        },
        {
          "name": "Create Group",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/groups",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"CSE-AI\",\n  \"educationType\": \"B.Tech\",\n  \"description\": \"Computer Science with AI specialization\"\n}" }
          }
        },
        {
          "name": "Update Group",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/groups/{{groupId}}",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete Group",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/groups/{{groupId}}" }
        }
      ]
    },
    {
      "name": "ADMIN — SUBJECTS (Shared)",
      "item": [
        {
          "name": "List Shared Subjects",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/subjects" }
        },
        {
          "name": "Create Shared Subject",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/subjects",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Machine Learning\",\n  \"group\": \"{{groupId}}\",\n  \"description\": \"ML for CSE-AI\",\n  \"color\": \"#10b981\"\n}" }
          }
        },
        {
          "name": "Update Shared Subject",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/admin/subjects/{{subjectId}}",
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Updated description\"\n}" }
          }
        },
        {
          "name": "Delete Shared Subject",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/admin/subjects/{{subjectId}}" }
        }
      ]
    }
  ]
}
